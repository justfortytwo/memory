# Local Ollama embedder (default model: qwen3-embedding:0.6b). Keep secrets out of the repo.
OLLAMA_BASE_URL=http://localhost:11434
EMBED_MODEL=qwen3-embedding:0.6b
# SQLite file path. Falls back to ./memory.db when unset. The *.db files are gitignored.
DB_PATH=memory.db
# Set RUN_OLLAMA_TESTS=1 to run the live-Ollama integration test.
RUN_OLLAMA_TESTS=0
