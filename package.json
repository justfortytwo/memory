{
  "name": "@justfortytwo/memory",
  "version": "0.1.5",
  "description": "Standalone semantic-memory MCP server (SQLite + sqlite-vec + Ollama embedder). persona-agnostic.",
  "license": "MIT",
  "author": {
    "name": "Enrico Deleo",
    "url": "https://enricodeleo.com"
  },
  "homepage": "https://forty-two.it",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/justfortytwo/memory.git"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "fortytwo-memory": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./contract": "./dist/contract.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "node dist/migrate.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^12.0.0",
    "knex": "^3.1.0",
    "sqlite-vec": "^0.1.6"
  },
  "peerDependencies": {
    "@justfortytwo/gate": "^0.1.0",
    "@justfortytwo/salience": "^0.1.0"
  },
  "peerDependenciesMeta": {
    "@justfortytwo/gate": {
      "optional": true
    },
    "@justfortytwo/salience": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
