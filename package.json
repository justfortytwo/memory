{
  "name": "@justfortytwo/guide",
  "version": "0.1.0",
  "description": "Standalone semantic-memory MCP server (SQLite + sqlite-vec + Ollama embedder). Ford-agnostic.",
  "license": "MIT",
  "author": { "name": "Enrico Deleo", "url": "https://enricodeleo.com" },
  "homepage": "https://forty-two.it",
  "repository": { "type": "git", "url": "git+https://github.com/justfortytwo/guide.git" },
  "type": "module",
  "engines": { "node": ">=18" },
  "bin": {
    "fortytwo-guide": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./contract": "./dist/contract.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "node dist/migrate.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.0.0",
    "knex": "^3.1.0",
    "sqlite-vec": "^0.1.6"
  },
  "peerDependencies": {
    "@justfortytwo/vogon": "^0.1.0",
    "@justfortytwo/deepthought": "^0.1.0"
  },
  "peerDependenciesMeta": {
    "@justfortytwo/vogon": { "optional": true },
    "@justfortytwo/deepthought": { "optional": true }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
